import pandas as pd
df=pd.read_csv(r'C:\Users\Lenovo\Downloads\Listado_de_Negocios_Verdes_20260316.csv')

#limpieza de datos
df.columns = df.columns.str.replace("\n"," ").str.strip()

#normalizacion de datos
df["DEPARTAMENTO (Donde se encuentra el Negocio Verde)"] = (
    df["DEPARTAMENTO (Donde se encuentra el Negocio Verde)"]
    .str.strip()
    .str.upper())

df["REGIÓN (Donde se encuentra el Negocio Verde)"] = (
    df["REGIÓN (Donde se encuentra el Negocio Verde)"]
    .str.strip()
    .str.upper())

df["Producto Principal (Que promueve el Negocio Verde)"] = (
    df["Producto Principal (Que promueve el Negocio Verde)"]
    .str.strip()
    .str.upper())

df["MUNICIPIO (Donde se encuentra el Negocio Verde)"] = (
    df["MUNICIPIO (Donde se encuentra el Negocio Verde)"]
    .str.strip()
    .str.upper())

df = df[(df["Producto Principal (Que promueve el Negocio Verde)"] != "No registra") &
    (df["REGIÓN (Donde se encuentra el Negocio Verde)"] != "No registra")& 
    (df["DEPARTAMENTO (Donde se encuentra el Negocio Verde)"] != "No registra")& 
    (df["MUNICIPIO (Donde se encuentra el Negocio Verde)"] != "No registra")]

    

